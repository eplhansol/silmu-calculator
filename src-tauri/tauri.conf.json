{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "직장인 계산기",
  "version": "0.2.1",
  "identifier": "com.hansol.vatcalc",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "직장인 계산기",
        "width": 760,
        "height": 920,
        "minWidth": 420,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
